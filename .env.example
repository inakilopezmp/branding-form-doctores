# Supabase (guardado del formulario y Storage para logos)
SUPABASE_API_KEY=your_supabase_anon_or_service_role_key
# Opcional si usas otra URL de proyecto:
# SUPABASE_URL=https://tu-proyecto.supabase.co

# Gemini (generación de logos)
# Obtén la clave en: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Modelo (opcional). Por defecto: gemini-2.5-flash-image. Alternativas: imagen-4.0-generate-001, imagen-4.0-ultra-generate-001.
# IMAGEN_MODEL=gemini-2.5-flash-image
